  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Temperaturas",
      "type": "row"
    },
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "spanNulls": true, "showPoints": "never"},
          "unit": "celsius",
          "min": 10,
          "max": 45
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 16, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"gemelo_telegraf\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) =>\n      r._field == \"temp_DS0\" or\n      r._field == \"temp_DS1\" or\n      r._field == \"temp_DS2\" or\n      r._field == \"temp_DS3\" or\n      r._field == \"temp_DS4\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ],
      "title": "Temperatura pared DS0–DS4 [°C]",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "spanNulls": true, "showPoints": "never"},
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 1},
      "id": 3,
      "options": {
        "legend": {"calcs": ["last"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"gemelo_telegraf\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"t_amb\" or r._field == \"t_sup\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
          "refId": "A"
        }
      ],
      "title": "T ambiente y T superior [°C]",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 10},
