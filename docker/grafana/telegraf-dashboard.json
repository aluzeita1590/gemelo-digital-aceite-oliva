          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {"text": "APAGADA",   "color": "green", "index": 0},
                "1": {"text": "ENCENDIDA", "color": "red",   "index": 1}
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 31},
      "id": 11,
      "options": {
        "alignValue": "center",
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true},
        "rowHeight": 0.9,
        "showValue": "always",
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "influxdb", "uid": "${DS_INFLUXDB}"},
          "query": "from(bucket: \"gemelo_telegraf\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"mqtt_consumer\")\n  |> filter(fn: (r) => r._field == \"bomba\")\n  |> map(fn: (r) => ({r with _value: if r._value then 1 else 0}))\n  |> yield(name: \"bomba\")",
          "refId": "A"
